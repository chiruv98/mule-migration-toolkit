spring:
  application:
    name: {{ app_name }}

  {% if has_db %}
  datasource:
    url: jdbc:postgresql://${DB_HOST:localhost}:${DB_PORT:5432}/${DB_NAME:{{ app_name | replace('-','_') }}}
    username: ${DB_USER:postgres}
    password: ${DB_PASSWORD:}
    hikari:
      maximum-pool-size: 10
      minimum-idle: 2
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
  {% endif %}

  {% if has_jms %}
  {% if jms_broker == 'activemq-artemis' %}
  artemis:
    mode: native
    host: ${JMS_HOST:localhost}
    port: ${JMS_PORT:61616}
    user: ${JMS_USER:admin}
    password: ${JMS_PASSWORD:admin}
  {% elif jms_broker == 'rabbitmq' %}
  rabbitmq:
    host: ${RABBITMQ_HOST:localhost}
    port: ${RABBITMQ_PORT:5672}
    username: ${RABBITMQ_USER:guest}
    password: ${RABBITMQ_PASSWORD:guest}
  {% endif %}
  {% endif %}

  {% if has_batch %}
  batch:
    job:
      enabled: false
  {% endif %}

server:
  port: ${PORT:8080}

management:
  endpoints:
    web:
      exposure:
        include: health,info,prometheus
  metrics:
    export:
      prometheus:
        enabled: true

resilience4j:
  retry:
    instances:
      default:
        max-attempts: 3
        wait-duration: 500ms
  circuitbreaker:
    instances:
      default:
        failure-rate-threshold: 50
        wait-duration-in-open-state: 10s
